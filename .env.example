# OpenClaw Super Advisor runtime template
# Version: 1.2.11
# Phase: P2.4
# Copy to state\.env for local runtime use. Never commit state\.env.

OPENCLAW_HOME=.
OPENCLAW_STATE_DIR=state
OPENCLAW_CONFIG_PATH=state\openclaw.json
OPENCLAW_WORKSPACE_DIR=workspace
OPENCLAW_LOG_LEVEL=info

OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_HOOKS_TOKEN=
ADVISOR_ENGINE_API_TOKEN=

AI_PROVIDER=
OPENAI_ENABLED=false
CLAUDE_ENABLED=false
GEMINI_ENABLED=false
DEEPSEEK_ENABLED=false
AI_PROVIDER_FALLBACK_ENABLED=false
AI_PROVIDER_FALLBACK_ORDER=openai,claude,gemini,deepseek
ALLOW_PAID_PROVIDER_SMOKE_TEST=false

OPENAI_MODEL=
CLAUDE_MODEL=
GEMINI_MODEL=
DEEPSEEK_MODEL=
OPENAI_TIMEOUT_SECONDS=
CLAUDE_TIMEOUT_SECONDS=
GEMINI_TIMEOUT_SECONDS=
DEEPSEEK_TIMEOUT_SECONDS=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=
TELEGRAM_TARGET_CHAT_ID=
TELEGRAM_GROUP_CHAT_ID=
TELEGRAM_THREAD_ID=

# Dual Telegram Bot architecture.
# Operator bot: user <-> super-advisor MAIN only. Market bot: approved outbound alerts only.
OPENCLAW_TELEGRAM_OPERATOR_ENABLED=false
OPENCLAW_TELEGRAM_OPERATOR_BOT_TOKEN=
OPENCLAW_TELEGRAM_OPERATOR_OWNER_USER_ID=
OPENCLAW_TELEGRAM_OPERATOR_ALLOWED_CHAT_IDS=
OPENCLAW_TELEGRAM_OPERATOR_MODE=polling
OPENCLAW_TELEGRAM_OPERATOR_WEBHOOK_ENABLED=false
OPENCLAW_TELEGRAM_MARKET_ENABLED=false
OPENCLAW_TELEGRAM_MARKET_BOT_TOKEN=
OPENCLAW_TELEGRAM_MARKET_TARGET_CHAT_ID=
OPENCLAW_TELEGRAM_MARKET_TARGET_THREAD_ID=
OPENCLAW_TELEGRAM_MARKET_INBOUND_ENABLED=false

# MT5 — 8 required symbols (read-only, advisor-only, no OrderSend)
MT5_ENABLED=false
MT5_TERMINAL_PATH=
MT5_USE_EXISTING_SESSION=true
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_XAUUSD_SYMBOL=XAUUSD
MT5_EURUSD_SYMBOL=EURUSD
MT5_GBPUSD_SYMBOL=GBPUSD
MT5_AUDUSD_SYMBOL=AUDUSD
MT5_NZDUSD_SYMBOL=NZDUSD
MT5_USDJPY_SYMBOL=USDJPY
MT5_USDCHF_SYMBOL=USDCHF
MT5_USDCAD_SYMBOL=USDCAD
MT5_DXY_SYMBOL=
MT5_US10Y_SYMBOL=

# FRED integration — free-tier or API key (DGS10 + DTWEXBGS)
# Free tier works without API key but has rate limits.
FRED_ENABLED=false
FRED_API_KEY=
FRED_BASE_URL=https://api.stlouisfed.org/fred
FRED_TIMEOUT_SECONDS=15
FRED_MAX_RETRIES=3
FRED_CACHE_TTL_SECONDS=3600
FRED_US10Y_SERIES_ID=DGS10
FRED_USD_BROAD_SERIES_ID=DTWEXBGS

# External heartbeat endpoint (optional — leave blank to use HEARTBEAT_EXTERNAL_NOT_CONFIGURED mode)
EXTERNAL_HEARTBEAT_ENDPOINT=
EXTERNAL_HEARTBEAT_SECRET=
HEARTBEAT_INTERVAL_SECONDS=60

ADVISOR_ONLY=true
EXECUTION_ALLOWED=false
ALLOW_ORDER_SEND=false
ADVISOR_ENGINE_HOST=127.0.0.1
ADVISOR_ENGINE_PORT=8765
ADVISOR_ENGINE_BASE_URL=http://127.0.0.1:8765
ADVISOR_TIMEZONE=Asia/Bangkok
ADVISOR_PRIMARY_SYMBOL=XAUUSD
ADVISOR_RUNTIME_MODE=bootstrap

OPENCLAW_HOOKS_ENABLED=false
OPENCLAW_HOOKS_PATH=/hooks
OPENCLAW_GATEWAY_HOST=127.0.0.1
OPENCLAW_GATEWAY_PORT=18789

ADVISOR_DATA_DIR=data
ADVISOR_LOG_DIR=logs
ADVISOR_DB_PATH=data\advisor.db

APP_ENV=development
DRY_RUN=true
SHADOW_MODE=true
LIVE_TELEGRAM_ALLOWED=false
REVEAL_SECRET_VALUES=false
