{
  "version": "1.2.1",
  "phase": "P2.1",
  "config": {
    "env": {
      "shellEnv": {
        "enabled": false
      }
    },
    "gateway": {
      "mode": "local",
      "bind": "loopback",
      "port": "18789",
      "auth": {
        "mode": "token",
        "token": {
          "source": "env",
          "provider": "default",
          "id": "OPENCLAW_GATEWAY_TOKEN"
