      },
      "controlUi": {
        "enabled": false
      }
    },
    "hooks": {
      "enabled": false,
      "path": "/hooks",
      "allowRequestSessionKey": false,
      "allowedAgentIds": [
        "super-advisor"
      ],
      "maxBodyBytes": 65536
    },
    "skills": [
      "advisor-safety-contract",
      "environment-health",
      "python-engine-bridge",
      "evidence-audit",
      "super-potential-review",
      "thai-telegram-publisher",
      "incident-reporting"
